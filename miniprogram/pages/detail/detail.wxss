/* pages/detail/detail.wxss */
.page { background: #0d1a0d; min-height: 100vh; }

.hero-img {
  position: relative;
  width: 100%;
  height: 440rpx;
  overflow: hidden;
}
.hero-img-el { width: 100%; height: 100%; }
.hero-mask {
  position: absolute;
  left: 0; right: 0; bottom: 0;
  height: 60%;
  background: linear-gradient(to top, #0d1a0d, rgba(13,26,13,0));
}
.hero-text {
  position: absolute;
  left: 32rpx;
  bottom: 28rpx;
}
.hero-name {
  font-size: 56rpx;
  font-weight: 900;
  color: #f5f0e8;
  text-shadow: 0 2rpx 12rpx rgba(0,0,0,0.6);
}
.hero-en {
  font-size: 26rpx;
  color: #c4bfb4;
  font-style: italic;
  margin-top: 4rpx;
}

.badges {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  padding: 24rpx 32rpx;
}
.badge {
  font-size: 22rpx;
  padding: 8rpx 20rpx;
  border-radius: 9999rpx;
  border: 1rpx solid rgba(200,169,110,0.25);
  color: #c4bfb4;
  background: rgba(255,255,255,0.03);
}

.section {
  padding: 28rpx 0;
  border-bottom: 1rpx solid rgba(200,169,110,0.1);
}
.sec-title {
  display: flex;
  align-items: center;
  gap: 14rpx;
  font-family: "Songti SC", "Noto Serif SC", serif;
  font-size: 34rpx;
  font-weight: 700;
  color: #dcc08a;
  margin-bottom: 16rpx;
}
.sec-bar {
  width: 6rpx;
  height: 32rpx;
  background: #c8a96e;
  border-radius: 4rpx;
}
.sec-text {
  font-size: 28rpx;
  line-height: 1.8;
  color: #c4bfb4;
  text-align: justify;
}

.efficacy-tags {
  display: flex;
  flex-wrap: wrap;
  margin-top: 16rpx;
}

.poem {
  font-size: 28rpx;
  line-height: 2;
  color: #c8a96e;
  background: rgba(200,169,110,0.05);
  border: 1rpx dashed rgba(200,169,110,0.25);
  padding: 28rpx;
  border-radius: 16rpx;
  text-align: center;
  letter-spacing: 2rpx;
  white-space: pre-line;
}

.share-tip {
  text-align: center;
  font-size: 24rpx;
  color: #8a8578;
  padding: 48rpx 40rpx 80rpx;
}
