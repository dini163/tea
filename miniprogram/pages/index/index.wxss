/* pages/index/index.wxss */
.page {
  min-height: 100vh;
  background: #0d1a0d;
}

/* ===== HERO ===== */
.hero {
  position: relative;
  padding: 80rpx 40rpx 60rpx;
  text-align: center;
  overflow: hidden;
}
.hero-glow {
  position: absolute;
  inset: 0;
  background:
    radial-gradient(ellipse 70% 50% at 50% 30%, rgba(200, 169, 110, 0.10), transparent 60%),
    radial-gradient(ellipse 50% 40% at 20% 80%, rgba(127, 176, 105, 0.07), transparent 50%);
  z-index: 0;
}
.hero-deco {
  position: absolute;
  inset: 0;
  z-index: 0;
  opacity: 0.12;
}
.hero-deco .leaf {
  position: absolute;
  font-size: 44rpx;
}
.hero-deco .leaf:nth-child(1) { left: 12%; top: 18%; }
.hero-deco .leaf:nth-child(2) { right: 14%; top: 24%; }
.hero-deco .leaf:nth-child(3) { left: 22%; bottom: 16%; }
.hero-deco .leaf:nth-child(4) { right: 20%; bottom: 22%; }

.hero-sub,
.hero-title,
.hero-line,
.hero-desc,
.hero-actions {
  position: relative;
  z-index: 1;
}
.hero-sub {
  font-size: 24rpx;
  letter-spacing: 8rpx;
  color: #8a8578;
  margin-bottom: 24rpx;
}
.hero-title {
  font-size: 96rpx;
  font-weight: 900;
  background: linear-gradient(135deg, #dcc08a, #c8a96e 50%, #a68b4b);
  -webkit-background-clip: text;
  background-clip: text;
  color: transparent;
  letter-spacing: 6rpx;
}
.hero-line {
  width: 100rpx;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, #c8a96e, transparent);
  margin: 28rpx auto;
}
.hero-desc {
  font-size: 26rpx;
  color: #c4bfb4;
  line-height: 1.8;
  max-width: 600rpx;
  margin: 0 auto 40rpx;
}
.hero-actions {
  display: flex;
  gap: 20rpx;
  justify-content: center;
}
.hero-btn {
  font-size: 26rpx;
  padding: 16rpx 36rpx;
  border-radius: 9999rpx;
  background: #c8a96e;
  color: #0d1a0d;
  font-weight: 600;
}
.hero-btn.ghost {
  background: transparent;
  border: 1rpx solid rgba(200, 169, 110, 0.4);
  color: #c8a96e;
}

/* ===== TOOLBAR ===== */
.toolbar {
  position: sticky;
  top: 0;
  z-index: 10;
  background: rgba(13, 26, 13, 0.92);
  backdrop-filter: blur(20rpx);
  padding: 20rpx 32rpx;
  border-bottom: 1rpx solid rgba(200, 169, 110, 0.15);
}
.search {
  position: relative;
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}
.search-icon {
  position: absolute;
  left: 24rpx;
  font-size: 26rpx;
  color: #8a8578;
}
.search-input {
  flex: 1;
  background: rgba(255, 255, 255, 0.04);
  border: 1rpx solid rgba(200, 169, 110, 0.15);
  border-radius: 9999rpx;
  padding: 16rpx 60rpx 16rpx 64rpx;
  color: #f5f0e8;
  font-size: 26rpx;
}
.search-ph { color: #8a8578; }
.search-clear {
  position: absolute;
  right: 24rpx;
  font-size: 26rpx;
  color: #8a8578;
  padding: 8rpx;
}
.tabs {
  display: flex;
  gap: 12rpx;
}
.tab {
  flex: 1;
  text-align: center;
  font-size: 26rpx;
  color: #c4bfb4;
  padding: 14rpx 0;
  border-radius: 9999rpx;
  border: 1rpx solid transparent;
}
.tab--active {
  color: #0d1a0d;
  background: #c8a96e;
  font-weight: 600;
}

/* ===== GROUPS ===== */
.groups {
  padding-top: 40rpx;
  padding-bottom: 40rpx;
}
.group-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin: 40rpx 0 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid rgba(200, 169, 110, 0.15);
}
.group-header:first-child { margin-top: 0; }
.group-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
}
.group-name {
  font-size: 38rpx;
  font-weight: 700;
  color: #f5f0e8;
}
.group-count {
  margin-left: auto;
  font-size: 22rpx;
  color: #8a8578;
}

.tea-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}
.tea-grid-item {
  width: 49%;
  margin-bottom: 24rpx;
}

.footer-quote {
  text-align: center;
  font-size: 26rpx;
  color: #8a8578;
  font-style: italic;
  padding: 60rpx 40rpx 80rpx;
}
