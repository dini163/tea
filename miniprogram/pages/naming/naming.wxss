/* pages/naming/naming.wxss */
.page { background: #0d1a0d; min-height: 100vh; }
.head { padding-top: 48rpx; }

.naming-row {
  background: rgba(26, 46, 26, 0.6);
  border: 1rpx solid rgba(200,169,110,0.15);
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
}
.naming-head {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 14rpx;
}
.naming-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #c8a96e;
}
.naming-actual {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 9999rpx;
  border: 1rpx solid;
  background: rgba(200,169,110,0.08);
}
.naming-reason {
  font-size: 26rpx;
  line-height: 1.7;
  color: #c4bfb4;
  margin-bottom: 16rpx;
}
.naming-meta {
  display: flex;
  gap: 14rpx;
}
.meta-pill {
  font-size: 22rpx;
  padding: 6rpx 18rpx;
  border-radius: 9999rpx;
  background: rgba(255,255,255,0.04);
  border: 1rpx solid rgba(200,169,110,0.15);
  color: #c4bfb4;
}
