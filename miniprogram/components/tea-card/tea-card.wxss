/* components/tea-card/tea-card.wxss */
.tea-card {
  position: relative;
  background: rgba(26, 46, 26, 0.6);
  border: 1rpx solid rgba(200, 169, 110, 0.15);
  border-radius: 24rpx;
  overflow: hidden;
  transition: transform 0.2s ease, border-color 0.2s ease;
}
.tea-card--hover {
  transform: translateY(-6rpx);
  border-color: rgba(200, 169, 110, 0.4);
}

.tea-card-img {
  position: relative;
  width: 100%;
  height: 320rpx;
  background: #1a2e1a;
  overflow: hidden;
}
.tea-card-img-el {
  width: 100%;
  height: 100%;
}
.tea-badge {
  position: absolute;
  top: 16rpx;
  left: 16rpx;
  font-size: 20rpx;
  padding: 4rpx 16rpx;
  border-radius: 9999rpx;
  color: #fff;
  font-weight: 500;
  z-index: 2;
}

.tea-card-body {
  padding: 24rpx;
}
.tea-card-name {
  font-size: 34rpx;
  font-weight: 600;
  color: #f5f0e8;
}
.tea-card-name-en {
  font-size: 22rpx;
  color: #8a8578;
  margin-bottom: 16rpx;
  font-style: italic;
}

.tea-card-info {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}
.tea-info-item {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  padding: 16rpx;
  background: rgba(255, 255, 255, 0.03);
  border-radius: 12rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.03);
}
.tea-info-label {
  font-size: 20rpx;
  color: #8a8578;
  letter-spacing: 2rpx;
}
.tea-info-value {
  font-size: 26rpx;
  color: #f5f0e8;
  font-weight: 500;
}
.tea-info-storage,
.tea-info-efficacy {
  grid-column: 1 / -1;
}
.tea-info-storage .tea-info-value {
  font-size: 24rpx;
  font-weight: 400;
  color: #c4bfb4;
}

.efficacy-tags {
  display: flex;
  flex-wrap: wrap;
  margin-top: 4rpx;
}
